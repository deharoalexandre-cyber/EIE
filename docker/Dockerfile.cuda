FROM nvidia/cuda:12.4.0-devel-ubuntu22.04 AS build
RUN apt-get update && apt-get install -y cmake git
WORKDIR /eie
COPY . .
RUN git submodule update --init || true
RUN cmake -B build -DGGML_CUDA=ON -DCMAKE_BUILD_TYPE=Release && cmake --build build -j$(nproc)

FROM nvidia/cuda:12.4.0-runtime-ubuntu22.04
COPY --from=build /eie/build/eie-server /usr/local/bin/
COPY presets/ /etc/eie/presets/
EXPOSE 8080
CMD ["eie-server", "--config", "/etc/eie/presets/generic.yaml"]
